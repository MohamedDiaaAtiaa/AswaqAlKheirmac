{
  "name": "aswaq-alkheir-admin",
  "private": true,
  "version": "1.0.0",
  "description": "أسواق الخير - لوحة التحكم",
  "author": "Aswaq Al Kheir",
  "type": "module",
  "main": "electron.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "electron .",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.aswaqalkheir.admin",
    "productName": "Aswaq Al Khair admin",
    "files": [
      "dist/**/*",
      "electron.cjs"
    ],
    "directories": {
      "output": "D:\\Apps"
    },
    "win": {
      "forceCodeSigning": false,
      "icon": "build/icon.png",
      "target": [
        "portable"
      ]
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.png",
      "category": "public.app-category.business"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.3",
    "@capacitor/cli": "^8.3.3",
    "@capacitor/core": "^8.3.3",
    "@capacitor/ios": "^8.3.3",
    "@supabase/supabase-js": "^2.39.0",
    "lucide-static": "^0.321.0"
  },
  "devDependencies": {
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2",
    "vite": "^5.0.0"
  }
}
